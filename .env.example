# Cortex — environment variables
# Copy to .env (Bun auto-loads it). Never commit .env — see .gitignore.

# --- Required for any Arkiv write ---

# Session-key EOA private key — held by the backend relayer. Funded via Braga faucet.
# Per CLAUDE.md "Ownership model": this is $creator (immutable attribution).
# Generate with: bun -e "console.log('0x' + Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('hex'))"
SESSION_KEY_PRIVATE_KEY=0x_session_key_here_64_hex_chars

# User's primary EOA — $owner of every entity. The signer behind SIWE + EIP-712.
# In the walkthrough this is the wallet you connect via MetaMask.
USER_PRIMARY_ADDRESS=0x_user_eoa_here_40_hex_chars

# --- Memory encryption-at-rest (sovereignty keystone) ---

# Memories are sealed with a key derived from your PRIMARY wallet (no key escrow).
# Provide EITHER the signature (preferred — the only secret a fresh machine needs)
# OR the primary private key (dev convenience; signs the derivation message locally).
# Without either, sealed memories cannot be opened — recall skips them (the
# sovereignty negative control). Generate a signature: bun scripts/derive-user-signature.ts
# CORTEX_USER_SIGNATURE=0x_65_byte_eip191_sig
# CORTEX_USER_PRIVATE_KEY=0x_primary_eoa_key_64_hex_chars

# --- Optional LLM provider (for embeddings + semantic distillation) ---

# Embedding provider (must yield exactly 1536-d to match RaBitQ). Resolution
# order in src/compression/embeddings.ts: OPENROUTER_API_KEY first, then
# COHERE_API_KEY. OpenRouter is OpenAI-compatible; default model
# openai/text-embedding-3-small is natively 1536-d. Override the model with
# OPENROUTER_EMBED_MODEL if needed (must still be 1536-d).
OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_EMBED_MODEL=openai/text-embedding-3-small
COHERE_API_KEY=co-...

# Anthropic for distillation (warm → semantic rule synthesis).
ANTHROPIC_API_KEY=sk-ant-...

# Optional override for the distillation model. Defaults to claude-opus-4-7.
# Other valid options: claude-sonnet-4-6, claude-haiku-4-5.
# ANTHROPIC_MODEL=claude-opus-4-7

# --- Synaptic Market (deferred — Braga cannot deploy escrow contracts) ---

# Listing publish + browse works via Arkiv attributes; GLM escrow in
# contracts/SynapticMarket.sol requires a chain that admits general EVM txs.
# MARKET_CONTRACT_ADDRESS=0x...

# --- Mirror daemon ---

# Path to the local SQLite mirror file. Default: ./cortex-mirror.sqlite
CORTEX_MIRROR_PATH=./cortex-mirror.sqlite

# --- Next.js / wallet UI ---

# Reown AppKit (WalletConnect). Omit to use injected MetaMask only.
# NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# NEXT_PUBLIC_BRAGA_RPC=https://braga.hoodi.arkiv.network/rpc
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Dashboard (legacy Bun server) ---

# Port for bun run dev:bun (src/ui-server.ts). Next.js defaults to 3000.
DASHBOARD_PORT=3000

# --- Optional: pin a custom RPC if you self-host ---
# Defaults to src/constants.ts BRAGA.httpRpc when unset.
# CORTEX_BRAGA_RPC=https://braga.hoodi.arkiv.network/rpc
# CORTEX_BRAGA_WS=wss://braga.hoodi.arkiv.network/rpc/ws

# --- Operational toggles (optional) ---

# Disable the dashboard's autonomous citation loop (read-only dashboard).
# CORTEX_AUTONOMOUS_LOOP=off

# Enable Bun's dev error overlay + HMR on the dashboard. Default off so wallet-
# extension errors never render as a fake "crashed" overlay. Set 1 while building.
# CORTEX_DEV=1

# How many blocks `scripts/backfill.ts` scans back from head. Default 5000.
# BACKFILL_BLOCKS=5000

# Silence the mirror daemon's verbose per-event logging.
# CORTEX_MIRROR_QUIET=1

# PROBE_QUERY / PROBE_ENTITY are set internally by scripts/sovereignty-proof.ts
# when it spawns scripts/_recall-probe.ts — not meant to be set by hand.
